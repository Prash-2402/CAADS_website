# CAADS Platform — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ─────────────────────────────────────────────────────
# Restrict signup to this email domain (e.g. srmist.edu.in)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=

# ── Resend (transactional email) ─────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=

# ── Gemini API (AI assistant) ────────────────────────────────
# Found in: Google AI Studio → API Keys
GEMINI_API_KEY=

# ── Google Drive API ─────────────────────────────────────────
# Found in: Google Cloud Console → APIs & Services → Credentials
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=

# ── App config ───────────────────────────────────────────────
# Base URL for the deployed app (used in QR code generation, email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
